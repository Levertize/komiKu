<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_filter_card"
    android:padding="16dp">

    <!-- Bottom Sheet Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/dk_border"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Setelan Membaca"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/dk_text" />

    <!-- SECTION 1: Reading View Mode -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MODE TAMPILAN"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/accent"
        android:layout_marginTop="16dp"
        android:letterSpacing="0.05" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <!-- Mode Vertical Scroll (Webtoon) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_mode_vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/accent"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/iv_mode_vertical"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_read_mode"
                    app:tint="@color/accent" />

                <TextView
                    android:id="@+id/tv_mode_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scroll Vertikal"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Mode Horizontal Swipe (Book) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_mode_horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/dk_border"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/iv_mode_horizontal"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/dk_muted" />

                <TextView
                    android:id="@+id/tv_mode_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Swipe Horisontal"
                    android:textSize="11sp"
                    android:textColor="@color/dk_muted"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dk_border"
        android:layout_marginVertical="16dp" />

    <!-- SECTION 2: Chapter Navigation List (Quick Jump) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DAFTAR CHAPTER (QUICK JUMP)"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/accent"
        android:letterSpacing="0.05" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_sheet_chapters"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="8dp"
        android:scrollbars="vertical" />

</LinearLayout>
