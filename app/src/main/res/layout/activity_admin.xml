<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dk_bg"
    android:fitsSystemWindows="true">

    <!-- Premium Header Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/admin_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/dk_card"
        app:cardElevation="2dp"
        app:cardMaxElevation="4dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/dk_border"
        app:cardCornerRadius="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Logo App -->
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_logo"
                android:layout_marginEnd="12dp"
                android:contentDescription="KomiKu Logo" />

            <!-- Title & Subtitle Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KomiKu Admin"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    android:letterSpacing="0.01" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Panel Manajemen Konten"
                    android:textSize="11sp"
                    android:textColor="@color/dk_muted"
                    android:layout_marginTop="1dp" />

            </LinearLayout>

            <!-- Logout Button with Red Accent Background Ripple -->
            <ImageButton
                android:id="@+id/btn_admin_logout"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_logout"
                android:background="@drawable/bg_clear_btn"
                app:tint="@color/color_hot"
                android:layout_marginEnd="8dp"
                android:contentDescription="Logout" />

            <!-- Close Button -->
            <ImageButton
                android:id="@+id/btn_admin_back"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/bg_clear_btn"
                app:tint="@color/dk_text"
                android:contentDescription="Kembali" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Comic List with Bottom Padding to avoid FAB overlap -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_admin_comics"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="96dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/admin_header"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Premium Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_comic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@drawable/ic_plus"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:backgroundTint="@color/accent"
        app:tint="@color/white"
        app:elevation="6dp"
        app:maxImageSize="28dp"
        android:contentDescription="Tambah Komik Baru" />

</androidx.constraintlayout.widget.ConstraintLayout>
