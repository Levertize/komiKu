<?xml version="1.0" encoding="utf-8"?>
<!--
  READING MODE ACTIVITY
  Theme: Theme.KomiKu.Reading
  Komponen:
  - TopBar (auto-hide saat scroll)
  - RecyclerView vertikal (halaman komik = gambar full-width)
  - BottomBar dengan Menu / Previous / Next
  - Scrollbar custom di sisi kanan
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/read_bg">

    <!-- ── PAGES RECYCLERVIEW ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_pages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- ── TOP BAR ── -->
    <LinearLayout
        android:id="@+id/read_topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/top_inset_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@color/read_bar_bg" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@color/read_bar_bg">

            <!-- Back button -->
            <ImageButton
                android:id="@+id/btn_read_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_chevron_left"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/dk_text"
                android:contentDescription="Back" />

            <!-- Title + chapter info (center) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="12dp">

                <TextView
                    android:id="@+id/tv_read_comic_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Comic Title"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_read_chapter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chapter Name"
                    android:textSize="10sp"
                    android:textColor="@color/dk_muted"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Bookmark button -->
            <ImageButton
                android:id="@+id/btn_bookmark"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_bookmark"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/dk_muted"
                android:contentDescription="Bookmark" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dk_border" />

    </LinearLayout>

    <!-- ── BOTTOM BAR ── -->
    <LinearLayout
        android:id="@+id/read_bottombar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dk_border" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/read_bar_bg"
            android:paddingBottom="12dp">

            <!-- Menu toggle -->
            <LinearLayout
                android:id="@+id/btn_read_menu"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_menu_lines"
                    app:tint="@color/dk_muted" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menu"
                    android:textSize="9sp"
                    android:textColor="@color/dk_muted"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Previous chapter -->
            <LinearLayout
                android:id="@+id/btn_prev_chapter"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="@color/dk_text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prev"
                    android:textSize="9sp"
                    android:textColor="@color/dk_text"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Next chapter -->
            <LinearLayout
                android:id="@+id/btn_next_chapter"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/dk_text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Next"
                    android:textSize="9sp"
                    android:textColor="@color/dk_text"
                    android:layout_marginTop="4dp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/bottom_inset_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@color/read_bar_bg" />

    </LinearLayout>

    <!-- Custom scrollbar indicator -->
    <View
        android:id="@+id/scroll_thumb"
        android:layout_width="4dp"
        android:layout_height="60dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_scroll_thumb"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
