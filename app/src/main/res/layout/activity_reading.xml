<?xml version="1.0" encoding="utf-8"?>
<!--
  READING MODE ACTIVITY
  Theme: Theme.KomiKu.Reading
  Komponen:
  - TopBar (auto-hide saat scroll)
  - RecyclerView vertikal (halaman komik = gambar full-width)
  - BottomBar dengan Menu / Previous / Next
  - Scrollbar custom di sisi kanan
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/read_bg">

    <!-- ── TOP BAR (auto-hide) ── -->
    <LinearLayout
        android:id="@+id/read_topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/read_bg"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back button -->
        <LinearLayout
            android:id="@+id/btn_read_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"

            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_chevron_left"
                app:tint="@color/dk_muted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_back"
                android:textSize="9.5sp"
                android:textColor="@color/dk_muted" />

        </LinearLayout>

        <!-- Title + chapter info (center) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_read_comic_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Naruto Shippuden"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_read_chapter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chapter 97 · Hal. 1/24"
                android:textSize="8.5sp"
                android:textColor="@color/dk_hint" />

        </LinearLayout>

        <!-- Bookmark button -->
        <ImageButton
            android:id="@+id/btn_bookmark"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_bookmark"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/dk_muted"
            android:contentDescription="Bookmark" />

    </LinearLayout>

    <!-- Top bar bottom border -->
    <View
        android:id="@+id/topbar_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dk_border"
        app:layout_constraintTop_toBottomOf="@id/read_topbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── PAGES RECYCLERVIEW ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topbar_divider"
        app:layout_constraintBottom_toTopOf="@id/bottom_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--
          RecyclerView vertikal: setiap item = 1 halaman komik
          Adapter: ReadingPageAdapter
          Item layout: item_reading_page.xml
          Gunakan snapHelper untuk snap per halaman (opsional):
            PagerSnapHelper().attachToRecyclerView(rv_pages)
        -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_pages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:scrollbars="none"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- Custom scrollbar indicator -->
        <View
            android:id="@+id/scroll_thumb"
            android:layout_width="3dp"
            android:layout_height="60dp"
            android:layout_gravity="end|top"
            android:layout_marginEnd="5dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_scroll_thumb"
            android:alpha="0.65" />

        <!-- Tap zones (klik kiri/kanan untuk prev/next halaman, opsional) -->
        <View
            android:id="@+id/tap_zone_prev"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <View
            android:id="@+id/tap_zone_next"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

    </FrameLayout>

    <!-- Bottom divider -->
    <View
        android:id="@+id/bottom_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dk_border"
        app:layout_constraintBottom_toTopOf="@id/read_bottombar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── BOTTOM BAR (auto-hide) ── -->
    <LinearLayout
        android:id="@+id/read_bottombar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/read_bg"
        android:paddingTop="8dp"
        android:paddingBottom="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Menu toggle -->
        <LinearLayout
            android:id="@+id/btn_read_menu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"

            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_menu_lines"
                app:tint="@color/dk_muted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_menu"
                android:textSize="8sp"
                android:textColor="@color/dk_hint" />

        </LinearLayout>

        <!-- Previous chapter -->
        <LinearLayout
            android:id="@+id/btn_prev_chapter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"

            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_chevron_left"
                app:tint="@color/dk_muted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_prev"
                android:textSize="8sp"
                android:textColor="@color/dk_hint" />

        </LinearLayout>

        <!-- Next chapter -->
        <LinearLayout
            android:id="@+id/btn_next_chapter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"

            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/dk_text"
                android:alpha="0.6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_next"
                android:textSize="8sp"
                android:textColor="@color/dk_muted"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
