<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dk_bg"
    android:fitsSystemWindows="true">

    <!-- Premium Header Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/chapter_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/dk_card"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/dk_border"
        app:cardCornerRadius="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btn_admin_chapter_back"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_clear_btn"
                android:src="@drawable/ic_chevron_left"
                android:contentDescription="Kembali"
                app:tint="@color/dk_text" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_admin_comic_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Comic Title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dk_text"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelola Chapter &amp; Konten PDF"
                    android:textSize="11sp"
                    android:textColor="@color/dk_muted"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Scrollable content wrapper for Form and List -->
    <!-- Form Chapter wrapped inside a beautiful CardView -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/form_chapter_card"
        style="@style/Widget.KomiKu.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/chapter_header">

        <LinearLayout
            android:id="@+id/form_chapter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INPUT DATA CHAPTER"
                android:textColor="@color/accent"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="12dp" />

            <!-- Chapter Number Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.KomiKu.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_chapter"
                app:startIconTint="@color/accent">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_chapter_number"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nomor Chapter (e.g. 10)"
                    android:inputType="number"
                    android:textColor="@color/dk_text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Chapter Title Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.KomiKu.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_chapter_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Judul Chapter (e.g. Fight to Death)"
                    android:inputType="text"
                    android:textColor="@color/dk_text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- PDF Selector Layout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_select_pdf"
                    style="@style/Widget.KomiKu.Button.Outline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_select_pdf"
                    android:textSize="11sp"
                    app:icon="@drawable/ic_chapter"
                    app:iconTint="@color/accent"
                    app:iconSize="14dp" />

                <!-- PDF File Status Container -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/dk_border"
                    app:cardBackgroundColor="@color/dk_card2"
                    app:cardCornerRadius="8dp">

                    <TextView
                        android:id="@+id/tv_selected_pdf_path"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_pdf_selected"
                        android:textSize="10sp"
                        android:textColor="@color/dk_muted"
                        android:padding="8dp"
                        android:maxLines="2"
                        android:ellipsize="end" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Save Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_chapter"
                style="@style/Widget.KomiKu.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Simpan Chapter"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Chapter List RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_admin_chapters"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/form_chapter_card"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
