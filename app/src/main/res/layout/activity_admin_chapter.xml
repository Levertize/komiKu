<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dk_bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/chapter_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/bg_detail_overlay"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_admin_chapter_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_chevron_left"
            android:contentDescription="Back"
            app:tint="@color/dk_text" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_admin_comic_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comic Title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/dk_text"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kelola Chapter &amp; Konten"
                android:textSize="12sp"
                android:textColor="@color/dk_muted"
                android:layout_marginTop="1dp" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/form_chapter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/chapter_header">

        <EditText
            android:id="@+id/et_chapter_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nomor Chapter (e.g. 10)"
            android:inputType="number"
            android:textColor="@color/dk_text"
            android:textColorHint="@color/dk_muted" />

        <EditText
            android:id="@+id/et_chapter_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Judul Chapter (e.g. Chapter 10 - Fight)"
            android:inputType="text"
            android:textColor="@color/dk_text"
            android:textColorHint="@color/dk_muted"
            android:layout_marginTop="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_select_pdf"
            style="@style/Widget.KomiKu.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_select_pdf"
            android:layout_marginTop="16dp"
            app:icon="@drawable/ic_chapter" />

        <TextView
            android:id="@+id/tv_selected_pdf_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_pdf_selected"
            android:textSize="10sp"
            android:textColor="@color/dk_hint"
            android:layout_marginTop="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_chapter"
            style="@style/Widget.KomiKu.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Simpan Chapter"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_admin_chapters"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/form_chapter"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
