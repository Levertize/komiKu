<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <!-- Nomor chapter (kotak kecil ungu) -->
    <TextView
        android:id="@+id/tv_chapter_number"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/accent"
        android:background="@drawable/bg_chapter_number" />

    <!-- Info chapter -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tv_chapter_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/dk_text"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_chapter_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/dk_muted" />

    </LinearLayout>

    <!-- Tombol baca -->
    <TextView
        android:id="@+id/tv_read_chapter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Baca"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/accent"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@drawable/bg_read_btn"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
