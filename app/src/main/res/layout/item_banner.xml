<?xml version="1.0" encoding="utf-8"?>
<!--
  BANNER ITEM untuk ViewPager2 di Home
  Sesuai desain HTML:
  - Background dark gradient
  - Accent diagonal bar di kanan
  - Badge TRENDING
  - Judul + chapter komik
  - Author + update info
  - Pagination dots di bawah kanan
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/accent_border"
    android:layout_marginHorizontal="2dp"
    android:layout_marginVertical="2dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Background gradient utama -->
        <View
            android:id="@+id/banner_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_banner_dark" />

        <!-- Accent bar diagonal di kanan -->
        <View
            android:id="@+id/banner_accent"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:alpha="0.15"
            android:background="@drawable/bg_banner_accent" />

        <!-- Badge TRENDING (kiri atas) -->
        <TextView
            android:id="@+id/tv_banner_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TRENDING"
            android:textSize="8sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.08"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_badge_accent"
            android:layout_margin="14dp" />

        <!-- Info komik (kiri bawah) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="120dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tv_banner_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:lineSpacingMultiplier="1.1" />

            <TextView
                android:id="@+id/tv_banner_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10.5sp"
                android:textColor="#CCFFFFFF"
                android:layout_marginTop="4dp"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="1" />

        </LinearLayout>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
