<?xml version="1.0" encoding="utf-8"?>
<!--
  SPLASH SCREEN
  Theme: Theme.KomiKu.Splash
  Duration: 2500ms lalu navigate ke LoginActivity (jika belum login)
             atau MainActivity (jika sudah login)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dk_bg">

    <!-- Glow effect (circular gradient background) -->
    <View
        android:id="@+id/view_glow"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/bg_glow_circle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="200dp" />

    <!-- Ring 1 -->
    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_ring"
        app:layout_constraintTop_toTopOf="@id/view_glow"
        app:layout_constraintBottom_toBottomOf="@id/view_glow"
        app:layout_constraintStart_toStartOf="@id/view_glow"
        app:layout_constraintEnd_toEndOf="@id/view_glow" />

    <!-- Ring 2 -->
    <View
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:background="@drawable/bg_ring_inner"
        app:layout_constraintTop_toTopOf="@id/view_glow"
        app:layout_constraintBottom_toBottomOf="@id/view_glow"
        app:layout_constraintStart_toStartOf="@id/view_glow"
        app:layout_constraintEnd_toEndOf="@id/view_glow" />

    <!-- Logo container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_logo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:cardBackgroundColor="@color/dk_card"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/accent_border"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="180dp" >

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_logo"
            android:contentDescription="@string/app_name" />

    </androidx.cardview.widget.CardView>

    <!-- App name -->
    <TextView
        android:id="@+id/tv_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="@dimen/text_title"
        android:textStyle="bold"
        android:letterSpacing="-0.02"
        android:textColor="@color/dk_text"
        android:fontFamily="@font/plus_jakarta_sans_bold"
        app:layout_constraintTop_toBottomOf="@id/card_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/tv_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_tagline"
        android:textSize="@dimen/text_sm"
        android:textColor="@color/dk_hint"
        android:letterSpacing="0.04"
        app:layout_constraintTop_toBottomOf="@id/tv_app_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp" />

    <!-- Loading dots -->
    <LinearLayout
        android:id="@+id/ll_dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="52dp"
        app:layout_constraintTop_toBottomOf="@id/tv_tagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Active dot (wider pill) -->
        <View
            android:id="@+id/dot_1"
            android:layout_width="18dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_dot_active"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/dot_2"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_dot_inactive"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/dot_3"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_dot_inactive" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
