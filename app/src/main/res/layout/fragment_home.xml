<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dk_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── TOP BAR ── -->
            <LinearLayout
                android:id="@+id/topbar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@color/dk_bg">

                <!-- Hamburger icon -->
                <ImageButton
                    android:id="@+id/btn_hamburger"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_hamburger"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Menu"
                    app:tint="@color/dk_muted" />

                <!-- Search bar -->
                <FrameLayout
                    android:id="@+id/btn_search_bar"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_search_bar"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:src="@drawable/ic_search"
                            app:tint="@color/dk_hint" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/hint_search_home"
                            android:textSize="10sp"
                            android:textColor="@color/dk_hint" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Avatar -->
                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_avatar_placeholder"
                    android:background="@drawable/bg_avatar"
                    android:contentDescription="Profil" />

            </LinearLayout>

            <!-- Top border -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dk_border" />

            <!-- ── BANNER CAROUSEL ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="4dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vp_banner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/banner_height"
                    android:paddingHorizontal="24dp"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:overScrollMode="never" />

                <!-- Pagination dots -->
                <LinearLayout
                    android:id="@+id/ll_banner_dots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp" />

            </FrameLayout>

            <!-- ── SECTION: TERPOPULER ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="13dp"
                android:paddingBottom="6dp">

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_popular"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    app:chipBackgroundColor="@color/accent_dim"
                    app:chipStrokeColor="@color/accent_border"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="20dp"
                    app:chipStartPadding="8dp"
                    app:chipEndPadding="8dp"
                    android:clickable="false"
                    android:focusable="false" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_see_all_popular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    android:textSize="9sp"
                    android:textColor="@color/accent"
                    android:alpha="0.65"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Grid: Terpopuler (3 kolom) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_popular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:overScrollMode="never"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3" />

            <!-- ── SECTION: KOMIK LAINNYA ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="13dp"
                android:paddingBottom="6dp">

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_others"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_soft"
                    app:chipBackgroundColor="#14C084FC"
                    app:chipStrokeColor="#47C084FC"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="20dp"
                    android:clickable="false"
                    android:focusable="false" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_see_all_others"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    android:textSize="9sp"
                    android:textColor="@color/accent"
                    android:alpha="0.65"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Grid: Komik Lainnya -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_others"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="12dp"
                android:overScrollMode="never"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>