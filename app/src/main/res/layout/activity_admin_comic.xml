<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dk_bg"
    android:fitsSystemWindows="true">

    <!-- Sleek Header Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/dk_card"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/dk_border"
        app:cardCornerRadius="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_clear_btn"
                android:src="@drawable/ic_chevron_left"
                android:contentDescription="Back"
                app:tint="@color/dk_text" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Tambah/Edit Komik"
                android:textColor="@color/dk_text"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Scrollable Editor Form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/layout_actions"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- SECTION 1: Cover & Format Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.KomiKu.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VISUAL &amp; FORMAT"
                        android:textColor="@color/accent"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <!-- Comic Cover Upload Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Beautiful Book Frame Preview -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="80dp"
                            android:layout_height="110dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/dk_border">
                            <ImageView
                                android:id="@+id/iv_cover_preview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@color/dk_card2"
                                android:scaleType="centerCrop"
                                android:contentDescription="Cover Preview" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cover Komik"
                                android:textColor="@color/dk_text"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rasio gambar 3:4. Gunakan format JPG/PNG dengan resolusi bersih."
                                android:textColor="@color/dk_muted"
                                android:textSize="10sp"
                                android:layout_marginTop="2dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_select_cover"
                                style="@style/Widget.KomiKu.Button.Outline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Pilih Gambar Cover"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dk_border"
                        android:layout_marginVertical="16dp" />

                    <!-- Format Selection Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pilih Format Komik"
                        android:textColor="@color/dk_text"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/cg_format"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true"
                        app:chipSpacingHorizontal="8dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_manga"
                            style="@style/Widget.KomiKu.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manga" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_manhwa"
                            style="@style/Widget.KomiKu.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manhwa" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_manhua"
                            style="@style/Widget.KomiKu.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manhua" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_webtoon"
                            style="@style/Widget.KomiKu.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Webtoon" />
                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 2: Detail Informasi Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.KomiKu.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INFORMASI KOMIK"
                        android:textColor="@color/accent"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <!-- Comic Title -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.KomiKu.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Judul Komik"
                        app:startIconDrawable="@drawable/ic_logo"
                        app:startIconTint="@color/accent">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/dk_text"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Author Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.KomiKu.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Author / Kreator"
                        app:startIconDrawable="@drawable/ic_nav_account"
                        app:startIconTint="@color/accent">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_author"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/dk_text"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Genres input list -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.KomiKu.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Genre (pisahkan dengan koma)"
                        app:startIconDrawable="@drawable/ic_filter"
                        app:startIconTint="@color/accent"
                        app:helperText="Contoh: Action, Fantasy, Adventure">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_genre"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/dk_text"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Synopsis / Description -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.KomiKu.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Sinopsis Komik">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top"
                            android:minLines="4"
                            android:textColor="@color/dk_text"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 3: Atribut & Estetika Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.KomiKu.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="METADATA &amp; WARNA"
                        android:textColor="@color/accent"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <!-- Rating and Badge Input Column -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.KomiKu.TextInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Rating (0-10)"
                            app:startIconDrawable="@drawable/ic_star"
                            app:startIconTint="@color/accent">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_rating"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:textColor="@color/dk_text"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.KomiKu.TextInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:hint="Badge (e.g. HOT)"
                            app:startIconDrawable="@drawable/ic_bell"
                            app:startIconTint="@color/accent">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_badge"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/dk_text"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dk_border"
                        android:layout_marginVertical="16dp" />

                    <!-- Cover Gradient Colors (Hex) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Warna Cover Detail (Hex Gradient)"
                        android:textColor="@color/dk_text"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Warna latar gradasi saat melihat info detail komik ini."
                        android:textColor="@color/dk_muted"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.KomiKu.TextInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Warna Mulai">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_color_start"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="#1A0E35"
                                android:textColor="@color/dk_text"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.KomiKu.TextInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:hint="Warna Selesai">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_color_end"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="#0D1840"
                                android:textColor="@color/dk_text"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Actions layout bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/dk_card"
        app:cardElevation="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/dk_border"
        app:cardCornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete"
                style="@style/Widget.KomiKu.Button.Outline"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:text="Hapus"
                android:textColor="@color/color_hot"
                android:textSize="13sp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone"
                app:strokeColor="@color/color_hot"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                style="@style/Widget.KomiKu.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Simpan Komik"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
