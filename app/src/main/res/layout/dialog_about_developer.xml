<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:strokeWidth="1.2dp"
    app:strokeColor="@color/dk_border"
    app:cardBackgroundColor="@color/dk_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- App Logo & Title -->
        <ImageView
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:src="@drawable/ic_logo"
            android:contentDescription="KomiKu Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KomiKu"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Versi 1.0 (Mobile PDF Comic Reader)"
            android:textSize="10sp"
            android:textColor="@color/dk_muted"
            android:layout_marginTop="2dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dk_border"
            android:layout_marginVertical="16dp" />

        <!-- Academic Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Universitas Muhammadiyah Purwokerto"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/dk_text"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Proyek Pemrograman Aplikasi Mobile"
            android:textSize="11sp"
            android:textColor="@color/accent_soft"
            android:layout_marginTop="4dp"
            android:gravity="center" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dk_border"
            android:layout_marginVertical="16dp" />

        <!-- Team Members Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIM PENGEMBANG (KELOMPOK 1)"
            android:textSize="9.5sp"
            android:textStyle="bold"
            android:textColor="@color/dk_muted"
            android:letterSpacing="0.08"
            android:layout_gravity="start"
            android:layout_marginBottom="8dp" />

        <!-- Member 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginVertical="3dp">
            <View
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:background="@drawable/bg_dot_inactive"
                android:backgroundTint="@color/accent"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mohamad Dimas Arjuna"
                android:textSize="12.5sp"
                android:textColor="@color/dk_text"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Member 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginVertical="3dp">
            <View
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:background="@drawable/bg_dot_inactive"
                android:backgroundTint="@color/accent"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Iqbal Dwi Ganjar"
                android:textSize="12.5sp"
                android:textColor="@color/dk_text"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Member 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginVertical="3dp">
            <View
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:background="@drawable/bg_dot_inactive"
                android:backgroundTint="@color/accent"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Erlangga Jaya Diputra"
                android:textSize="12.5sp"
                android:textColor="@color/dk_text"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dk_border"
            android:layout_marginVertical="16dp" />

        <!-- Actions -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_github"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Hubungkan GitHub"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="#24292E"
            app:icon="@drawable/ic_github"
            app:iconTint="@color/white"
            app:iconSize="16dp"
            app:cornerRadius="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_close"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tutup"
            android:textSize="12sp"
            android:textColor="@color/dk_muted"
            app:rippleColor="#1A7C5CFC" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
