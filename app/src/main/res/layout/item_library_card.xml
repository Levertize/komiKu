<?xml version="1.0" encoding="utf-8"?>
<!--
  ITEM: Library card untuk grid 2 kolom
  Digunakan oleh: LibraryAdapter (rv_library)
  Layout: thumbnail + judul + progress bar + chapter info
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="@color/dk_card"
    app:cardCornerRadius="13dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/dk_border"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Thumbnail (rasio 16:10) -->
        <ImageView
            android:id="@+id/iv_lib_thumb"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:background="@color/dk_card2"
            android:contentDescription="Cover"
            android:src="@drawable/ic_placeholder_thumb"/>

        <!-- Gunakan ConstraintLayout di adapter untuk set ratio 16:10 via layoutParams -->

        <!-- Info section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="10dp"
            >

            <!-- Title -->
            <TextView
                android:id="@+id/tv_lib_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/dk_text"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/pb_lib_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/progress_height"
                android:progressDrawable="@drawable/progress_lib"
                android:max="100"
                android:progress="0" />

            <!-- Chapter progress text -->
            <TextView
                android:id="@+id/tv_lib_chapter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="8sp"
                android:textColor="@color/dk_hint" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
