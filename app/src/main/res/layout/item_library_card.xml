<?xml version="1.0" encoding="utf-8"?>
<!--
  ITEM: Library card untuk grid 2 kolom
  Digunakan oleh: LibraryAdapter (rv_library)
  Layout: thumbnail + judul + progress bar + chapter info
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/dk_card"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeWidth="1.2dp"
    app:strokeColor="@color/dk_border"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Thumbnail wrapper for better rounding and overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp">

            <ImageView
                android:id="@+id/iv_lib_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/dk_card2"
                android:contentDescription="Cover" />

            <!-- Dark gradient overlay for title readability -->
            <View
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_detail_overlay" />

            <!-- Progress chip overlay -->
            <TextView
                android:id="@+id/tv_lib_chapter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="10dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:background="@drawable/bg_badge_accent"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <!-- Delete Button (Top-Right Overlay) -->
            <ImageButton
                android:id="@+id/btn_delete_lib"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:src="@drawable/ic_trash"
                android:background="@drawable/bg_circle_white_trans"
                app:tint="#F43F5E"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:contentDescription="Hapus dari Library" />

        </FrameLayout>

        <!-- Info section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tv_lib_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/dk_text"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Custom progress bar container -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <ProgressBar
                    android:id="@+id/pb_lib_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progressDrawable="@drawable/progress_lib"
                    android:max="100"
                    android:progress="0" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
