<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <!-- Thumbnail container dengan rasio 3:4 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0">

        <!-- Trick rasio 3:4: pakai padding top 133% -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Spacer untuk rasio 3:4 (paddingTop = 133% width) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:id="@+id/ratio_anchor"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    app:layout_constraintDimensionRatio="3:4"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    xmlns:app="http://schemas.android.com/apk/res-auto"/>

                <!-- Thumbnail cover (gradient diset dari kode) -->
                <ImageView
                    android:id="@+id/iv_comic_thumb"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Cover"
                    app:layout_constraintTop_toTopOf="@id/ratio_anchor"
                    app:layout_constraintBottom_toBottomOf="@id/ratio_anchor"
                    app:layout_constraintStart_toStartOf="@id/ratio_anchor"
                    app:layout_constraintEnd_toEndOf="@id/ratio_anchor"
                    xmlns:app="http://schemas.android.com/apk/res-auto"/>

                <!-- Badge HOT / NEW / UPDATE -->
                <TextView
                    android:id="@+id/tv_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="6.5sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:letterSpacing="0.05"
                    android:visibility="gone"
                    android:layout_margin="5dp"
                    app:layout_constraintTop_toTopOf="@id/ratio_anchor"
                    app:layout_constraintStart_toStartOf="@id/ratio_anchor"
                    xmlns:app="http://schemas.android.com/apk/res-auto"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Judul komik -->
    <TextView
        android:id="@+id/tv_comic_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textColor="#E2E0F0"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Chapter -->
    <TextView
        android:id="@+id/tv_chapter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="8sp"
        android:textColor="#4DF0EEF8"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

</LinearLayout>
