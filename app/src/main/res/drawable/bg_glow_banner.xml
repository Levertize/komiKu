<?xml version="1.0" encoding="utf-8"?>
<!--
  Glowing Neon shadow drawable for highlighth banners.
  Created using layered shapes with decreasing size and increasing opacity.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer thick soft glow (5% opacity) -->
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <solid android:color="#057C5CFC" />
        </shape>
    </item>

    <!-- Outer soft glow 2 (11% opacity) -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <solid android:color="#0B7C5CFC" />
        </shape>
    </item>

    <!-- Middle glow 1 (20% opacity) -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#147C5CFC" />
        </shape>
    </item>

    <!-- Middle glow 2 (32% opacity) -->
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="#207C5CFC" />
        </shape>
    </item>

    <!-- Inner glow 1 (43% opacity) -->
    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#2B7C5CFC" />
        </shape>
    </item>

    <!-- Inner thick glow (64% opacity) -->
    <item android:left="10dp" android:top="10dp" android:right="10dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#407C5CFC" />
        </shape>
    </item>
</layer-list>
